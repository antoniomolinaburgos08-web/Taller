{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Configuración del sitio",
    "description": "Configuración global del sitio web"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true,
      "default": "El Taller de Migue"
    },
    "tagline": {
      "type": "string",
      "default": "Tu mecánico de confianza en Benifla"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "address": {
      "type": "string",
      "default": "Moli Nou 8, 46722 Benifla, Valencia"
    },
    "phone": {
      "type": "string",
      "default": "625 78 64 38"
    },
    "email": {
      "type": "email",
      "default": "info@eltallerdemigue.es"
    },
    "whatsapp": {
      "type": "string",
      "default": "34625786438"
    },
    "schedule": {
      "type": "json"
    },
    "googleMapsUrl": {
      "type": "string"
    },
    "googleReviewUrl": {
      "type": "string"
    },
    "socialLinks": {
      "type": "json"
    },
    "seoDescription": {
      "type": "text"
    },
    "seoKeywords": {
      "type": "text"
    },
    "chatwootEnabled": {
      "type": "boolean",
      "default": false
    },
    "chatwootToken": {
      "type": "string"
    },
    "chatwootUrl": {
      "type": "string",
      "default": "http://localhost:3000"
    },
    "gaTrackingId": {
      "type": "string",
      "description": "ID de propiedad de Google Analytics 4 (G-XXXXXXXXXX)"
    },
    "gtmContainerId": {
      "type": "string",
      "description": "ID de contenedor de Google Tag Manager (GTM-XXXXXX)"
    },
    "fbPixelId": {
      "type": "string",
      "description": "ID de píxel de Facebook / Meta"
    },
    "telegramBotToken": {
      "type": "string",
      "description": "Token del bot de Telegram (BotFather)",
      "private": true
    },
    "telegramChatId": {
      "type": "string",
      "description": "Chat ID donde el bot envía notificaciones"
    },
    "openaiApiKey": {
      "type": "string",
      "description": "API key para OCR e IA (OpenAI o Anthropic)",
      "private": true
    },
    "wallapopEnabled": {
      "type": "boolean",
      "default": false
    },
    "cochesnetEnabled": {
      "type": "boolean",
      "default": false
    },
    "cochesnetDealerId": {
      "type": "string",
      "description": "ID de profesional de coches.net (para el feed XML)"
    },
    "whatsappCatalogEnabled": {
      "type": "boolean",
      "default": false
    },
    "whatsappBusinessAccountId": {
      "type": "string",
      "description": "ID de cuenta de WhatsApp Business (Meta)"
    },
    "whatsappCatalogId": {
      "type": "string",
      "description": "ID del catálogo de WhatsApp Business"
    },
    "whatsappAccessToken": {
      "type": "string",
      "description": "Token de acceso permanente de Meta Graph API",
      "private": true
    }
  }
}
