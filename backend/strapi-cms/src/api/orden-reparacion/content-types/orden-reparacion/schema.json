{
    "kind": "collectionType",
    "collectionName": "orden_reparacions",
    "info": {
        "singularName": "orden-reparacion",
        "pluralName": "orden-reparacions",
        "displayName": "Orden de Reparación",
        "description": "Flujo completo del vehículo en el taller"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "numero_orden": {
            "type": "uid",
            "targetField": "matricula"
        },
        "matricula": {
            "type": "string",
            "required": true
        },
        "cliente": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::cliente.cliente"
        },
        "estado": {
            "type": "enumeration",
            "enum": [
                "Pendiente",
                "Diagnostico",
                "En Taller",
                "Esperando Piezas",
                "Control Calidad",
                "Terminado",
                "Entregado",
                "Facturado"
            ],
            "default": "Pendiente"
        },
        "sintomas": {
            "type": "text",
            "required": true
        },
        "diagnostico": {
            "type": "richtext"
        },
        "trabajos_realizados": {
            "type": "richtext"
        },
        "kilometros_entrada": {
            "type": "integer"
        },
        "fecha_entrada": {
            "type": "datetime"
        },
        "fecha_salida": {
            "type": "datetime"
        },
        "fecha_entrega": {
            "type": "datetime"
        },
        "presupuesto_estimado": {
            "type": "decimal"
        },
        "coste_piezas": {
            "type": "decimal"
        },
        "coste_mano_obra": {
            "type": "decimal"
        },
        "anomalias": {
            "type": "json",
            "description": "Array de {tipo, ubicacion, gravedad} para rayaduras, faros rotos, etc."
        },
        "tramites_pendientes": {
            "type": "json",
            "description": "Array de {tipo: ITV|Informe pericial|Seguro|Transferencia, estado, notas, fecha_limite}"
        },
        "fotos_entrada": {
            "type": "media",
            "multiple": true,
            "required": false,
            "allowedTypes": ["images"]
        },
        "fotos_salida": {
            "type": "media",
            "multiple": true,
            "required": false,
            "allowedTypes": ["images"]
        },
        "requiere_paso_taller_antes_venta": {
            "type": "boolean",
            "default": false
        },
        "stock_vehicle_asociado": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "api::stock-vehicle.stock-vehicle"
        },
        "trabajadores": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::trabajador.trabajador",
            "inversedBy": "ordenes_asignadas"
        },
        "piezas_usadas": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::pieza-usada.pieza-usada",
            "mappedBy": "orden_reparacion"
        },
        "review_whatsapp_enviado": {
            "type": "boolean",
            "default": false
        }
    }
}
