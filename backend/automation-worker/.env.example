# ============================================================
# Automation Worker - Variables de entorno (plantilla)
# ============================================================
# Copia a `.env` y rellena tus valores reales.

# Puerto del servicio HTTP (por defecto 4000)
PORT=4000

# CORS: dominios que pueden llamar a este servicio
ALLOWED_ORIGINS=https://eltallerdemigue.es,https://www.eltallerdemigue.es,http://localhost:5500

# Strapi: donde vive el CRM (con token de API para leer/escribir)
STRAPI_URL=https://cms.eltallerdemigue.es
STRAPI_TOKEN=token_de_api_generado_en_strapi_admin

# --- IA para OCR de facturas y textos ---
# Usa el SDK oficial de Anthropic. Consigue tu clave en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# Modelo a usar (por defecto uno rápido y económico)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Bot de Telegram (@BotFather) ---
# Habla con @BotFather → /newbot → guarda el token
TELEGRAM_BOT_TOKEN=1234567890:ABCDEF-Tu-Token-Del-Bot
# Chat ID del dueño (para enviar publicaciones al móvil)
# Sácalo escribiendo al bot y consultando https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_OWNER_CHAT_ID=123456789

# --- WhatsApp Business API (Meta) ---
# Solo si tienes cuenta profesional aprobada
META_ACCESS_TOKEN=EAAxxxxxxxxx
META_CATALOG_ID=1234567890

# --- WhatsApp Cloud API (Meta) para avisos automáticos ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# --- Webhook de Chatwoot (respuestas SÍ/NO de citas) ---
CHATWOOT_WEBHOOK_SECRET=

# --- Crons (citas 9h/17h, mantenimientos 8h, cortesía 10h) ---
CRON_ENABLED=true
# --- Portales de venta (coches.net, Wallapop, AutoScout24, FB Marketplace) ---
# Clave para cifrar las contraseñas de los portales (AES-256-GCM).
# Genera una única con:  openssl rand -hex 32
PORTAL_CRYPTO_KEY=

# --- Almacenamiento de ficheros ("el drive donde se guarda todo") ---
# Backend: nextcloud | drive
STORAGE_BACKEND=nextcloud
# Nextcloud (usa una CONTRASEÑA DE APLICACIÓN, no la real)
NEXTCLOUD_URL=https://drive.eltallerdemigue.es
NEXTCLOUD_USER=taller
NEXTCLOUD_PASSWORD=
# Google Drive (opcional, alternativa a Nextcloud)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
