# ============================================================
# El Taller de Migue — Variables de entorno del stack de producción
# Copia este archivo a `.env` y rellena tus valores reales.
# NUNCA subas `.env` a git.
# ============================================================

# --- Dominios ---
# Deben apuntar (registros DNS "A") a la IP pública del VPS.
DOMAIN_WEB=eltallerdemigue.es
DOMAIN_CMS=cms.eltallerdemigue.es
DOMAIN_CHAT=chat.eltallerdemigue.es

# Email para Let's Encrypt (avisos de renovación de certificados)
ACME_EMAIL=info@eltallerdemigue.es

# ============================================================
# Strapi
# ============================================================
STRAPI_DB_NAME=strapi
STRAPI_DB_USER=strapi
# Genera con: openssl rand -base64 24
STRAPI_DB_PASSWORD=cambia_esta_password_de_bd

# Secretos de Strapi. Genera cada uno con: openssl rand -base64 24
# APP_KEYS necesita 4 valores separados por coma:
#   openssl rand -base64 24 && openssl rand -base64 24 && openssl rand -base64 24 && openssl rand -base64 24
STRAPI_APP_KEYS=clave1,clave2,clave3,clave4
STRAPI_API_TOKEN_SALT=genera_con_openssl_rand
STRAPI_ADMIN_JWT_SECRET=genera_con_openssl_rand
STRAPI_TRANSFER_TOKEN_SALT=genera_con_openssl_rand
STRAPI_JWT_SECRET=genera_con_openssl_rand
STRAPI_ENCRYPTION_KEY=genera_con_openssl_rand

# ============================================================
# Chatwoot
# ============================================================
CHATWOOT_DB_NAME=chatwoot
CHATWOOT_DB_USER=chatwoot
CHATWOOT_DB_PASSWORD=cambia_esta_password_de_bd
CHATWOOT_REDIS_PASSWORD=cambia_esta_password_de_redis
# Genera con: openssl rand -hex 64
CHATWOOT_SECRET_KEY_BASE=genera_con_openssl_rand_hex_64
