# ============================================================
# Ajustes específicos de Chatwoot (SMTP, configuración general)
# Copia este archivo a `chatwoot.env` y rellena tus valores.
# El stack lo carga en los servicios chatwoot-web y chatwoot-worker.
# ============================================================

RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
INSTALLATION_ENV=docker

# Cerrar auto-registro (solo tú y tus agentes pueden crear cuenta)
ENABLE_ACCOUNT_SIGNUP=false

# Forzar HTTPS (Caddy ya sirve HTTPS delante)
FORCE_SSL=true

# ------- SMTP (para invitar agentes y recuperar contraseñas) -------
# Ejemplo con Gmail / Google Workspace usando contraseña de aplicación:
#   https://support.google.com/accounts/answer/185833
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_DOMAIN=eltallerdemigue.es
SMTP_USER_NAME=info@eltallerdemigue.es
SMTP_PASSWORD=contraseña_de_aplicación
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
MAILER_SENDER_EMAIL=El Taller de Migue <info@eltallerdemigue.es>
