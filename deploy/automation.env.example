# ============================================================
# Automation Worker - Variables sensibles (copiar a automation.env)
# El stack de producción lo carga en el contenedor `automation`.
# ============================================================

# Token de API creado en Strapi Admin → Settings → API Tokens (permisos Full access)
STRAPI_TOKEN=

# IA (Anthropic Claude Vision) para OCR de facturas
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Bot de Telegram del taller
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# WhatsApp Business API (Meta Graph)
META_ACCESS_TOKEN=
META_CATALOG_ID=
# --- Portales de venta (coches.net, Wallapop, AutoScout24, FB Marketplace) ---
# Clave para cifrar las contraseñas de los portales (AES-256-GCM).
# Genera una única con:  openssl rand -hex 32
PORTAL_CRYPTO_KEY=

# --- Almacenamiento de ficheros ("el drive donde se guarda todo") ---
# Backend: nextcloud | drive
STORAGE_BACKEND=nextcloud
# Nextcloud (usa una CONTRASEÑA DE APLICACIÓN, no la real)
NEXTCLOUD_URL=https://drive.eltallerdemigue.es
NEXTCLOUD_USER=taller
NEXTCLOUD_PASSWORD=
# Google Drive (opcional, alternativa a Nextcloud)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
