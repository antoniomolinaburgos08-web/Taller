# ============================================================
# El Taller de Migue - Variables de entorno (PLANTILLA)
# Copia este archivo a `.env` y rellena tus valores reales.
# El archivo `.env` NUNCA se sube a Git.
# ============================================================

# --- Secretos de Strapi (genera valores nuevos con: openssl rand -base64 16) ---
APP_KEYS=clave1,clave2,clave3,clave4
API_TOKEN_SALT=cambiame
ADMIN_JWT_SECRET=cambiame
TRANSFER_TOKEN_SALT=cambiame
ENCRYPTION_KEY=cambiame
JWT_SECRET=cambiame

# --- URL del frontend (para CORS del backend) ---
FRONTEND_URL=https://tu-frontend.vercel.app
